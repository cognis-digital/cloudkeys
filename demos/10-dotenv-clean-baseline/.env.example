# A well-formed .env.example: documents what the app needs WITHOUT real values.
# This is what a committed env template SHOULD look like — cloudkeys finds
# nothing, and CI stays green.

APP_ENV=production
LOG_LEVEL=info

# Cloud credentials are referenced by name only; real values live in the
# platform secret store / are injected at runtime.
AWS_ACCESS_KEY_ID=__SET_VIA_SECRET_MANAGER__
AWS_SECRET_ACCESS_KEY=__SET_VIA_SECRET_MANAGER__
AWS_DEFAULT_REGION=us-east-1

GCP_PROJECT_ID=demo-analytics-472310
GOOGLE_APPLICATION_CREDENTIALS=/var/run/secrets/gcp-key.json

AZURE_STORAGE_ACCOUNT=tfstatedemo
AZURE_CLIENT_ID=00000000-0000-0000-0000-000000000000

FEATURE_FLAG=enable_new_dashboard
MAX_CONNECTIONS=42
